HETZNER_STORAGEBOX_HOST=<storagebox-user-id>.your-storagebox.de
HETZNER_STORAGEBOX_USER=<storagebox-user-id>
HETZNER_STORAGEBOX_PASSWORD=<your-storagebox-password>
HETZNER_STORAGEBOX_PORT=23
# Optional: override auto-detected plan (BX11/BX21/BX31/BX41)
# HETZNER_STORAGEBOX_PRODUCT=BX31

TRUENAS_BASE_URL=https://your-truenas-ip-or-hostname
TRUENAS_API_KEY=your-api-key-here
TRUENAS_VERIFY_SSL=true

DB_PATH=/data/storage.db
COLLECTION_INTERVAL_HOURS=1
WEB_PORT=8000
